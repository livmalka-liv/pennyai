# Copy this to .env and fill in your values

# App
DEBUG=false

# Database (Supabase PostgreSQL URL)
DATABASE_URL=postgresql://user:password@host:5432/pennyai

# Redis (for Celery job queue)
REDIS_URL=redis://localhost:6379/0

# LLM - set USE_MOCK_LLM=false and fill in one key to use real AI
USE_MOCK_LLM=true
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Market Data - set USE_MOCK_DATA=false and fill in one key
USE_MOCK_DATA=true
POLYGON_API_KEY=...
DATABENTO_API_KEY=...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TESTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...
STRIPE_PRICE_ELITE_YEARLY=price_...

# Auth (JWT)
JWT_SECRET=change-me-in-production-use-256-bit-random-string
